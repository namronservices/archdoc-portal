# --- Database ---
POSTGRES_USER=archdoc
POSTGRES_PASSWORD=archdoc
POSTGRES_DB=archdoc
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host port for optional external DB access (avoids clashing with a local 5432).
POSTGRES_HOST_PORT=5433

# Full SQLAlchemy URL (used by backend; overrides host/port if set)
DATABASE_URL=postgresql+psycopg2://archdoc:archdoc@postgres:5432/archdoc

# --- Backend ---
BACKEND_PORT=8000
# Filesystem roots (inside the backend container)
GIT_DATA_ROOT=/data/git
ARTIFACTS_ROOT=/data/artifacts

# Fixed commit author (no auth in Phase 1)
GIT_AUTHOR_NAME=ArchDoc Portal
GIT_AUTHOR_EMAIL=portal@archdoc.local

# --- Frontend ---
FRONTEND_PORT=5173
# Base URL the browser uses to reach the backend
VITE_API_BASE_URL=http://localhost:8000
